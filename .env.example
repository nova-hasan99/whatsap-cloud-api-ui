# --- Frontend (Vite) ---
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Public webhook URL shown in the admin "Numbers" setup panel.
# Set to: https://YOUR_PROJECT.supabase.co/functions/v1/whatsapp-webhook
VITE_WEBHOOK_URL=https://YOUR_PROJECT.supabase.co/functions/v1/whatsapp-webhook

# --- Edge functions (set via `supabase secrets set` — do NOT commit) ---
# SUPABASE_URL                (auto-injected)
# SUPABASE_SERVICE_ROLE_KEY   (auto-injected)
# META_GRAPH_VERSION=v21.0
