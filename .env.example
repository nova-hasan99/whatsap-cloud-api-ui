# Copy this file to .env.local and fill in all values.
# Never commit .env.local to git.

# ── Supabase project ────────────────────────────────────────────
# Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_WEBHOOK_URL=https://YOUR_PROJECT_REF.supabase.co/functions/v1/whatsapp-webhook

# Dashboard → Project Settings → API → anon_key + service_role (secret)
VITE_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Dashboard → Account (top-right avatar) → Access Tokens → Generate new token
SUPABASE_ACCESS_TOKEN=sbp_your_personal_access_token_here

# ── Admin login (created by npm run setup) ──────────────────────
ADMIN_NAME=Admin
VITE_ADMIN_EMAIL=admin@example.com
VITE_ADMIN_PASSWORD=changeme123

# ── Dev autofill (optional) ──────────────────────────────────────
# Set VITE_DEV_AUTOFILL=true to pre-fill the login form automatically.
# Only use this locally - these values are visible in the browser bundle.
VITE_DEV_AUTOFILL=false
